# ============================================================
# BootSeed 配置示例
# 复制为 .env 后按实际环境修改
# ============================================================

# PXE 网卡名称(必须真实存在并处于 UP 状态)
PXE_INTERFACE=ens192

# PXE 监听子网(必须是网络地址,不是地址池)
PXE_SUBNET=192.168.10.0

# PXE 服务端 IP(必须配置在 PXE_INTERFACE 上)
PXE_SERVER_IP=192.168.10.20

# Web/Agent 端口
HTTP_PORT=8080
AGENT_PORT=8080

# 部署完成后是否自动重启目标节点
AUTO_REBOOT=false

# 是否允许在前端指定自定义镜像服务器(开启后会扩大攻击面)
ALLOW_CUSTOM_IMAGE_SERVER=false

# 是否允许选择 multipath 顶层设备
ALLOW_MULTIPATH_TARGET=false

# 是否允许没有稳定路径的磁盘
ALLOW_UNSTABLE_DISK_NAME=false

# 是否允许通过 HTTPS 拉取镜像
ENABLE_HTTPS_IMAGES=true

# 受支持的架构(逗号分隔,目前只支持 x86_64 与 aarch64)
SUPPORTED_ARCHITECTURES=x86_64,aarch64

# Alpine 版本(必须固定到一个已经验证过的版本)
ALPINE_VERSION=3.20.3
ALPINE_BRANCH=v3.20

# Alpine 内核 flavor
ALPINE_X86_KERNEL_FLAVOR=lts
ALPINE_ARM64_KERNEL_FLAVOR=lts

# iPXE 版本(git tag 或 commit)
IPXE_REF=v2.0.0

# 内核控制台参数(不同架构默认不同串口)
X86_KERNEL_CONSOLE=console=tty0 console=ttyS0,115200n8
ARM64_KERNEL_CONSOLE=console=tty0 console=ttyAMA0,115200n8 console=ttyS0,115200n8

# 设备等待超时(秒)
NETWORK_DEVICE_TIMEOUT=60
STORAGE_DEVICE_TIMEOUT=90

# Agent 版本(写入 manifest.json)
AGENT_VERSION=0.1.0

# 服务端门户(bootseed-server)
PORTAL_TOKEN=bootseed
BOOTSEED_ENTER_SECRET=
NODE_ONLINE_TIMEOUT=45
HEARTBEAT_INTERVAL=15
